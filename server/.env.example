PORT=5000
# If you see EADDRINUSE on 5000 (e.g. PostgreSQL), use 5001 and set client VITE_DEV_API_TARGET.
# PORT=5001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Required for production verification
GEMINI_API_KEY=
# Default in code is gemini-1.5-flash (broad availability). If you hit 429 quota on a model, switch, e.g.:
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash
# Retries on HTTP 429 (rate limit). Optional; default 5.
# GEMINI_MAX_RETRIES=5
TAVILY_API_KEY=

# Optional: persist uploads & reports
MONGODB_URI=

# Cap claims per run (cost + latency control)
MAX_CLAIMS_TO_VERIFY=18
